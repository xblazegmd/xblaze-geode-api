{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "xblazegmd.geode-api",
	"name": "Xblaze's Geode API",
	"version": "v1.1.0",
	"developer": "XblazeGMD",
	"description": "Bunch of utils for my mods",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0",
		"jouca.badgesapi": ">=1.4.1"
	},
	"links": {
		"homepage": "https://xblaze.netlify.app",
		"source": "https://github.com/xblazegmd/xblaze-geode-api"
	},
	"resources": {
		"sprites": [
			"resources/*.png"
		]
	},
	"api": {
		"include": [
			"include/*.hpp"
		]
	},
	"settings": {
		"supporter-badge": {
			"type": "bool",
			"name": "Show Supporter Badges",
			"description": "Whether to show a supporter badge on a player's profile if they've supported XblazeGMD on his Patreon",
			"default": true
		},
		"remove": {
			"type": "custom:remove-btn"
		}
	}
}
